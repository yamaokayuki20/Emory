{
  "name": "emory",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check:spec": "node scripts/check-spec.ts",
    "check": "npm run typecheck && npm run check:spec",
